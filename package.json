{
  "name": "atlas-station",
  "version": "1.0.0",
  "description": "Hermes local organism and ATLAS executive surface for evidence-backed autonomous development",
  "main": "main.cjs",
  "scripts": {
    "test": "node tests/behavioral.mjs",
    "test:smoke": "node tests/smoke.mjs",
    "test:fleet": "node tests/fleet.test.mjs",
    "test:wing": "node tests/wing.test.mjs",
    "test:wing:d2": "node tests/wing-d2.test.mjs",
    "test:wing:felt": "node tests/wing-felt.test.mjs",
    "test:grader": "node tests/grader.test.mjs",
    "test:shim": "node tests/shim.test.mjs",
    "test:mission": "node tests/mission.test.mjs",
    "test:providers": "node tests/codex-provider.test.mjs && node tests/continuity.test.mjs",
    "test:renderer": "node tests/renderer-contract.mjs",
    "test:renderer:live": "electron tests/renderer-harness.cjs",
    "test:rate-build": "node tests/rate-build-contract.mjs",
    "test:outcome-audit": "node tests/outcome-audit-contract.mjs",
    "test:proposal-audit": "node tests/proposal-audit-contract.mjs",
    "test:quality-metrics": "node tests/quality-metrics.test.mjs",
    "test:autonomy-loop": "node tests/autonomy-loop-contract.mjs",
    "test:fleet-lifecycle": "node tests/fleet-lifecycle-contract.mjs",
    "test:goal-resolution": "node tests/goal-resolution-contract.mjs",
    "test:goal-audit": "node tests/goal-audit-contract.mjs",
    "test:goal-audit:strict": "npm run audit:goals:strict",
    "test:decision-loop": "node tests/decision-loop.test.cjs",
    "test:decision-integration": "node tests/decision-loop-integration.test.cjs",
    "test:xenosoma": "node tests/xenosoma.test.cjs",
    "test:memcontext-async": "node tests/memcontext-async-contract.mjs",
    "test:memory-continuity": "node tests/memory-continuity-contract.cjs",
    "test:population": "node tests/population-measurement.test.mjs",
    "test:extended": "npm run test:fleet && npm run test:wing && npm run test:wing:d2 && npm run test:wing:felt && npm run test:grader && npm run test:mission",
    "test:all": "npm test && npm run test:providers && npm run test:rate-build && npm run test:outcome-audit && npm run test:proposal-audit && npm run test:quality-metrics && npm run test:autonomy-loop && npm run test:fleet-lifecycle && npm run test:goal-resolution && npm run test:goal-audit && npm run test:goal-audit:strict && npm run test:decision-loop && npm run test:decision-integration && npm run test:xenosoma && npm run test:memcontext-async && npm run test:memory-continuity && npm run test:population && npm run test:renderer && npm run test:renderer:live && npm run test:extended",
    "test:full": "npm run test:all && npm run test:smoke",
    "audit:outcomes": "node scripts/audit-outcomes.mjs",
    "audit:goals": "node scripts/audit-goals.mjs",
    "audit:goals:strict": "node scripts/audit-goals.mjs --strict",
    "audit:proposals": "node scripts/audit-proposals.mjs",
    "measure:variant": "node scripts/measure_variant.mjs",
    "spiral:seal": "node scripts/spiral-receipt.cjs",
    "v1:status": "node scripts/v1-readiness.cjs",
    "v1:verify": "node scripts/v1-readiness.cjs --full --organism --write",
    "v1:release": "node scripts/v1-readiness.cjs --full --organism --release --write",
    "start": "electron ."
  },
  "keywords": ["hermes", "atlas", "codex", "autonomy", "agent-orchestration"],
  "author": "Daniel",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@huggingface/transformers": "^3.8.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0"
  },
  "devDependencies": {
    "electron": "^42.5.0"
  }
}
